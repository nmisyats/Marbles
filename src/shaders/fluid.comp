#version 430 core

//[
layout (local_size_x = 64) in;
//]

struct Pa { // Particle
    vec4 pm; // pos_m
    vec4 vd; // vel_d
    vec4 fp; // for_p
};
//[
layout(std430, binding=0) buffer PB { // particle buffer
    Pa ps[];
};
//]
#define R(i) ps[i].pm.xyz
#define M(i) ps[i].pm.w
#define V(i) ps[i].vd.xyz
#define D(i) ps[i].vd.w
#define F(i) ps[i].fp.xyz
#define P(i) ps[i].fp.w

layout(std430, binding=1) buffer BB { // bbox buffer
    vec4 bboxMin;
    vec4 bboxMax;
    vec4 barycenter;
    ivec4 gridSize;
    ivec4 voxelRanges[];
};

layout(std430, binding=2) buffer VB { // voxel buffer
    int voxelParticles[];
};

layout(std430, binding=3) buffer FB { // frame buffer
    vec4 frameBuffer[];
};

layout(std430, binding=4) buffer MB { // music buffer
    float musicBuffer[];
};

layout(location=0) uniform ivec4 params;
layout(location=1) uniform int option;
layout(location=2) uniform int whatGrid;

const int sampleRate = 44100;

ivec2 res = params.xy;
int frame = params.z;
float time = float(params.w)/float(sampleRate);

const float PI = 3.1415926535;
const float TWOPI = 6.28318530718;

const int N_PARTICLES = 1024*4;
const int MAX_CELLS = 32*32*32;
const int CELL_CAPACITY = 128;

const float DT = 0.01;
const float PARTICLE_MASS = 0.1;
const float KERNEL_RADIUS = 0.2;
const float PRESSURE_K = 1.0;
const float RHO0_SCALE = 20.0 / 1024.0;
const float VISCOSITY_MU = 0.5;
const float TENSION_SIGMA = 0.5;

const float BOUNDARY_RADIUS = 2.0;

const float WALL_STIFFNESS = 100.0;
const float WALL_DAMPING = 20.0;
const float RESTITUTION = 0.5;
const float TANGENTIAL_DAMPING = 0.98;

const int RM_MAX_STEPS = 64;
const float RM_EPS = 0.001;
const int TRACE_MAX_VOXELS = 92;
const float PARTICLE_RADIUS = 0.06;
const float SMIN_K = 0.004;

const float BBOX_MARGIN = 0.1;
const float PHYSICS_CELL_SIZE = KERNEL_RADIUS;
const float RENDER_CELL_SIZE = 2*PARTICLE_RADIUS;

int numCells = gridSize.x*gridSize.y*gridSize.z;

vec3 bboxCenter = 0.5 * (bboxMin.xyz + bboxMax.xyz);
vec3 bboxSize = bboxMax.xyz - bboxMin.xyz;
vec3 cellSize = bboxSize / vec3(gridSize);
vec3 bboxHalfSize = 0.5 * bboxSize;
vec3 cellHalfSize = 0.5 * cellSize;



int cellToIdx(ivec3 cell) {
    return cell.x + cell.y * gridSize.x + cell.z * gridSize.x * gridSize.y;
}

ivec3 idxToCell(int idx) {
    int ix =  idx % gridSize.x;
    int iy = (idx / gridSize.x) % gridSize.y;
    int iz =  idx / (gridSize.x * gridSize.y);
    return ivec3(ix, iy, iz);
}

ivec3 posToCell(vec3 p) {
    ivec3 cell = ivec3(floor((p - bboxMin.xyz) / cellSize));
    //cell = clamp(cell, ivec3(0), ivec3(gridSize) - 1);
    return cell;
}

vec3 cellCenter(ivec3 cell) {
    return bboxMin.xyz + vec3(cell) * cellSize + cellHalfSize;
}

// hash function by David Hoskins: https://www.shadertoy.com/view/4djSRW
vec3 hash33(vec3 p3) {
	p3 = fract(p3 * vec3(.1031, .1030, .0973));
    p3 += dot(p3, p3.yxz+33.33);
    return fract((p3.xxy + p3.yxx)*p3.zyx);
}

// from: https://iquilezles.org/articles/morenoise/
float noise(vec3 x) {
    vec3 p = floor(x);
    vec3 w = fract(x);

    /*vec3 u = w*w*w*(w*(w*6.0-15.0)+10.0);
    vec3 du = 30.0*w*w*(w*(w-1.0)+2.0);*/
    vec3 u = smoothstep(0., 1., w);
    vec3 du = 6.0 * w * (1.0 - w);
    
    vec2 q = vec2(1,0);
    float a = hash33( p+q.yyy ).x;
    float b = hash33( p+q.xyy ).x;
    float c = hash33( p+q.yxy ).x;
    float d = hash33( p+q.xxy ).x;
    float e = hash33( p+q.yyx ).x;
    float f = hash33( p+q.xyx ).x;
    float g = hash33( p+q.yxx ).x;
    float h = hash33( p+q.xxx ).x;

    float k0 =   a;
    float k1 =   b - a;
    float k2 =   c - a;
    float k3 =   e - a;
    float k4 =   a - b - c + d;
    float k5 =   a - c - e + g;
    float k6 =   a - b - e + f;
    float k7 = - a + b + c - d + e - f - g + h;

    return k0 + k1*u.x + k2*u.y + k3*u.z + k4*u.x*u.y + k5*u.y*u.z + k6*u.z*u.x + k7*u.x*u.y*u.z;
}

mat2 rot(float a) {
    float c = cos(a);
    float s = sin(a);
    return mat2(c, -s, s, c);
}

// from: https://iquilezles.org/articles/intersectors/
vec2 boxIntersect(vec3 ro, vec3 inv_rd, vec3 c, vec3 b)  {
    vec3 n = inv_rd*(ro-c);
    vec3 k = abs(inv_rd)*b;
    vec3 t1 = -n - k;
    vec3 t2 = -n + k;
    float tN = max( max( t1.x, t1.y ), t1.z );
    float tF = min( min( t2.x, t2.y ), t2.z );
    if( tN>tF || tF<0.0) return vec2(-1.0);
    return vec2( tN, tF );
}

// SPH simulation
// Particle-Based Fluid Simulation for Interactive Applications
// Muller et al. 2003

float Wpoly6(vec3 rvec, float h) {
    float r = length(rvec);
    if (r <= h) {
        float h3 = h*h*h;
        float h9 = h3*h3*h3;
        float hr = h*h - r*r;
        return (1.566/h9)*hr*hr*hr; // (315/(64*PI*h9))
    }
    return 0;
}

vec4 gradLapWpoly6(vec3 rvec, float h) {
    float r = length(rvec);
    if (r <= h) {
        float r2 = r*r;
        float h2 = h*h;
        float h3 = h2*h;
        float h9 = h3*h3*h3;
        float hr = h*h - r*r;
        float factor = -(9.4/h9); // -(945/(32*PI*h9))
        float l = (h2-r2)*(3*h2 - 7*r2);
        vec3 g = hr*hr*rvec;
        return factor*vec4(g, l);
    }
    return vec4(0);
}

vec3 gradWspiky(vec3 rvec, float h) {
    float r = length(rvec);
    if(r <= h && r > 1e-3) {
        float h3 = h*h*h;
        float h6 = h3*h3;
        float hr = h - r;
        float factor = -(14.324/h6)*hr*hr/r; // -(45/(PI*h6))
        return factor * rvec;
    }
    return vec3(0);
}

float lapWviscosity(vec3 rvec, float h) {
    float r = length(rvec);
    if(r <= h) {
        float h3 = h*h*h;
        float h6 = h3*h3;
        return (14.324/h6)*(h-r); // (45/(PI*h6))
    }
    return 0;
}

ivec2 getNeighborRange(ivec3 c, int ni) {
    ivec3 t = ivec3(ni, ni/3, ni/9) % 3;
    ivec3 n = c + min(t,1)*(1-2*(t/2));
    /*if(any(lessThan(n, ivec3(0))) || any(greaterThan(n, gridSize.xyz-1))) {
        return ivec2(0);
    }*/
    ivec3 n0 = clamp(n, ivec3(0), gridSize.xyz-1);
    if(all(equal(n0, n))) return voxelRanges[cellToIdx(n0)].xy;
    return ivec2(0);
}

ivec2 getNeighborRange(int i, int ni) {
    ivec3 c = posToCell(R(i));
    return getNeighborRange(c, ni);
}

void computePressureAndDensity(int i) {
    // compute density and pressure at particle i
    const float h = KERNEL_RADIUS;
    float rho = 0.;
    /*for(uint j = 0; j < N_PARTICLES; j++) {
        rho += M(j) * Wpoly6(R(i) - R(j), h);
    }*/
    for (int oi = 0; oi < 27; oi++) {
        ivec2 range = getNeighborRange(i, oi);
        for(int s = range.x; s < range.y; s++) {
            int j = voxelParticles[s];
            rho += M(j) * Wpoly6(R(i) - R(j), h);
        }
    }
    float rho0 = RHO0_SCALE * float(N_PARTICLES);
    D(i) = rho; // density
    P(i) = PRESSURE_K*(rho - rho0); // pressure
}

void computePressureForce(int i) {
    const float h = KERNEL_RADIUS;
    vec3 fPressure = vec3(0.);
    /*for(uint j = 0; j < N_PARTICLES; j++) {
        float factor = M(j) * (P(i) + P(j)) / (2.*D(j));
        vec3 fij = gradWspiky(R(i) - R(j), h);
        fPressure += factor * fij;
    }*/
    for (int oi = 0; oi < 27; oi++) {
        ivec2 range = getNeighborRange(i, oi);
        for(int s = range.x; s < range.y; s++) {
            int j = voxelParticles[s];
            float factor = M(j) * (P(i) + P(j)) / (2.*D(j));
            vec3 fij = gradWspiky(R(i) - R(j), h);
            fPressure += factor * fij;
        }
    }
    F(i) -= fPressure;
}

void computeViscosityForce(int i) {
    const float h = KERNEL_RADIUS;
    vec3 fViscosity = vec3(0.);
    /*for(uint j = 0; j < N_PARTICLES; j++) {
        vec3 fij = (V(j) - V(i)) * M(j) / D(j);
        fij *= lapWviscosity(R(i) - R(j), h);
        fViscosity += fij;
    }*/
    for (int oi = 0; oi < 27; oi++) {
        ivec2 range = getNeighborRange(i, oi);
        for(int s = range.x; s < range.y; s++) {
            int j = voxelParticles[s];
            vec3 fij = (V(j) - V(i)) * M(j) / D(j);
            fij *= lapWviscosity(R(i) - R(j), h);
            fViscosity += fij;
        }
    }
    F(i) += VISCOSITY_MU*fViscosity;
}

void computeSurfaceTensionForce(int i) {
    const float h = KERNEL_RADIUS;
    // compute surface tension force
    // 1. compute normal vector
    vec4 nl = vec4(0);
    /*for(uint j = 0; j < N_PARTICLES; j++) {
        float factor = M(j) / D(j);
        vec3 nij = factor * gradWpoly6(R(i) - R(j), h);
        n += nij;
        lap += factor * lapWpoly6(R(i) - R(j), h);
    }*/
    for (int oi = 0; oi < 27; oi++) {
        ivec2 range = getNeighborRange(i, oi);
        for(int s = range.x; s < range.y; s++) {
            int j = voxelParticles[s];
            float factor = M(j) / D(j);
            nl += factor * gradLapWpoly6(R(i) - R(j), h);
        }
    }
    // 2. compute tension force
    vec3 n = nl.xyz;
    float lap = nl.w;
    if(dot(n,n) > 1e-2) {
        F(i) -= TENSION_SIGMA*lap*normalize(n);
    }
}

bool T(float t, inout float x, float s, float e) {
    //t = floor(t/(4*DT))*4*DT;
    x = (t - s) / (e - s);
    return t >= s && t < e;
}

void computeExternalForces(int i) {
    vec3 fExt = vec3(0);

    vec3 p = R(i);
    vec3 v = V(i);
    vec3 u = normalize(p);
    float r = length(p);
    float x = 0.;

    if(T(time,x,0,10)) {
        fExt = -0.1*r*u;
    }
    if(T(time,x,10,20)) {
        fExt = vec3(0., mix(0., -0.3, smoothstep(0., 0.1, x)), 0.);
    }
    if(T(time,x,20,40)) {
        fExt = vec3(0., -0.3, 0.);
        mat2 m = rot(5.*x);
        fExt.xy *= m;
        fExt.zx *= m;
    }
    if(T(time,x,40,60)) {
        fExt = -0.1*r*u*smoothstep(0.,0.5,x);
    }
    if(T(time,x,60,80)) {
        vec3 h = vec3(0,1,0);
        float y = 5.*x;
        h.xy *= rot(y);
        h.zx *= rot(y);
        fExt = -3.*dot(p,h)*h + 0.1*r*u;
    }
    if(T(time,x,80,100)) {
        fExt = -0.1*r*u;
    }
    if(T(time,x,100,120)) {
        fExt = 1.*(0.5/(0.5+r))*u;
    }
    if(T(time,x,120,121)) {
        fExt = -0.5*r*u;
    }
    if(T(time,x,130,160)) {
        fExt = vec3(0., -0.25, 0.)*sin(x*5.*2.*PI);
        mat2 m = rot(2.*x);
        fExt.xy *= m;
        fExt.zx *= m;
    }
    if (r > BOUNDARY_RADIUS) {
        float vn = dot(u, v);
        fExt += -WALL_STIFFNESS*(r-BOUNDARY_RADIUS)*u - WALL_DAMPING*vn*u;
    }

    F(i) += fExt*max(D(i), 1e-6) - 10.*v;
}

void updateEulerStep(int i) {
    // compute acceleration
    vec3 f = F(i);
    vec3 a = f / max(D(i), 1e-6);

    // update pos/vel with semi-implicit Euler step
    // TODO: better integration
    vec3 r_old = R(i);
    vec3 v_old = V(i);
    vec3 v_new = v_old + a*DT;
    vec3 r_new = r_old + v_new*DT;

    // boundary
    if (length(r_new) > BOUNDARY_RADIUS) {
        vec3 u = normalize(r_new);
        r_new = u * BOUNDARY_RADIUS;
        float vn = dot(v_new, u);
        vec3 vNormal = vn * u;
        vec3 vTangent = v_new - vNormal;

        if (vn > 0.0) {
            vNormal *= -RESTITUTION;
        }

        v_new = vNormal + vTangent*TANGENTIAL_DAMPING;
    }

    R(i) = r_new;
    V(i) = v_new;
}

void initParticle(int i) {
    int n = N_PARTICLES;
    int nx = int(ceil(pow(float(n), 1.0 / 3.0)));
    int ny = nx;
    int nz = int(ceil(float(n) / float(nx * ny)));

    int ix = i % nx;
    int iy = (i / nx) % ny;
    int iz = i / (nx * ny);

    vec3 denom = max(vec3(nx,ny,nz)-1, vec3(1));
    vec3 uvw = vec3(ix, iy, iz) / denom;
    R(i) = mix(vec3(-1.0), vec3(1.0), uvw);
    V(i) = vec3(0);
    M(i) = PARTICLE_MASS * (1 - 0.5*hash33(vec3(i)).x);
    //M(i) = PARTICLE_MASS;
}

