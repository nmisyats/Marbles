        computeViscosityForce(gid);
    }
    if(option == 3) {
        //if (gid >= N_PARTICLES) return;
        computeSurfaceTensionForce(gid);
        computeExternalForces(gid);
        updateEulerStep(gid);
    }

    // determine bbox ranges
    // single workgroup
    if (option == 4) {
