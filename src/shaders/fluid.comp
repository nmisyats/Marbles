const int maxCurrParticles = 32;
vec4 currentParticles[maxCurrParticles];
int nCurrParticles = 0;
int currentCellIdx = -1;

void updateCurrentCell(vec3 p) {
    ivec3 c = posToCell(p);
    int idx = cellToIdx(c);
    if (idx == currentCellIdx) return;

    currentCellIdx = idx;
    nCurrParticles = 0;

    int flag = voxelRanges[idx].z;
    if (flag == 0) return;

    vec3 cc = cellCenter(c);
    for (int oi = 0; oi < 27; oi++) {
        if ((flag & (1 << oi)) != 0) {
            ivec2 range = getNeighborRange(c, oi);
            for(int s = range.x; s < range.y; s++) {
                vec4 p = ps[voxelParticles[s]].pm;
                float r = 1.3*PARTICLE_RADIUS*p.w/PARTICLE_MASS;
                vec3 q = max(abs(p.xyz - cc) - cellHalfSize, 0);
                if(dot(q,q) < r*r){
                    currentParticles[nCurrParticles++] = p;
                    if (nCurrParticles == maxCurrParticles) return;
                }
            }
        }
    }
}

// from: https://iquilezles.org/articles/smin/
vec4 smin(vec4 a, vec4 b, float k) {
    k *= 4.0;
    float h = max(k-abs(a.w-b.w),0.0)/(2.0*k);
    return vec4(mix(a.xyz,b.xyz,(a.w<b.w)?h:1.0-h),
                min(a.w,b.w)-h*h*k);
}

vec4 map(vec3 p) {
    // assuming p is within a non empty voxel neighborhood
    updateCurrentCell(p);
    vec4 gd = vec4(100);
    for(int i = 0; i < nCurrParticles; i++) {
        vec4 ci = currentParticles[i];
        vec3 ri = p - ci.xyz;
        float di = length(ri) - PARTICLE_RADIUS*ci.w/PARTICLE_MASS;
        gd = smin(gd, vec4(ri, di), SMIN_K);
    }
    return gd;
}

// returns non-unit normal, distance
vec4 raymarch(vec3 ro, vec3 rd, float tmin, float tmax, inout float shad) {
    // assumes ro is inside the bounding box
    float t = tmin;
    for(int i = 0; i < RM_MAX_STEPS && t < tmax; i++){
        vec4 m = map(ro + rd*t);
        float d = abs(m.w);
        if(d < RM_EPS){
            shad = 0.;
            return vec4(m.xyz, t);
        }
        shad = min(shad, 32.*d/max(t, 1e-3));
        t += d;
    }
    return vec4(-1);
}

vec4 sceneIntersect(vec3 ro, vec3 rd, out float shad) {
    vec3 inv_rd = 1.0/rd;
    vec2 bbox = boxIntersect(ro, inv_rd, bboxCenter, bboxHalfSize-1e-3);
    // traverse the grid inside the bounding box
    shad = 1.0;
    float t = max(bbox.x, 0); // ensure ray starts at or after ro
    vec4 hit = vec4(-1);
    for(int i = 0; i < TRACE_MAX_VOXELS && t < bbox.y; i++) { // if no bbox intersect, bbox.y < 0 < t, so this is skipped
        vec3 p = ro + rd*t;
        ivec3 cell = posToCell(p);
        float exit = boxIntersect(p, inv_rd, cellCenter(cell), cellHalfSize).y;
        vec4 rm = raymarch(ro, rd, t, t + exit, shad);
        if(rm.w >= 0){ // hit during raymarch
            return rm;
        }
        t += exit + 1e-3; // ensure exit this voxel
    }
    return vec4(-1);
}

mat3 buildBasis(vec3 N) {
    vec3 T = normalize(cross(N, abs(N.z) > 0.99 ? vec3(1,0,0) : vec3(0,0,1)));
    vec3 B = normalize(cross(N, T));
    return mat3(T, B, N);
}


// PBR from: https://learnopengl.com/PBR/Theory

float D_GGX(vec3 N, vec3 H, float a) {
    float a2 = a*a;
    float NdotH = max(dot(N, H), 0.);
    float NdotH2 = NdotH*NdotH;
    float nom = a2;
    float denom = (NdotH2 * (a2 - 1.) + 1.);
    denom = PI * denom * denom;
    return nom / denom;
}

float G_SchlickGGX(float NdotV, float k) {
    float nom = NdotV;
    float denom = NdotV * (1 - k) + k;
    return nom / denom;
}
  
float G_Smith(vec3 N, vec3 V, vec3 L, float k) {
    float NdotV = max(dot(N, V), 0.);
    float NdotL = max(dot(N, L), 0.);
    float ggx1 = G_SchlickGGX(NdotV, k);
    float ggx2 = G_SchlickGGX(NdotL, k);
    return ggx1 * ggx2;
}

vec3 F_Schlick(float cosTheta, vec3 F0) {
    return F0 + (1 - F0) * pow(1. - cosTheta, 5.);
}

vec3 sampleHemisphereDir(vec2 seed) {
    float z = seed.x;
    float phi = 2. * PI * seed.y;
    float r = sqrt(max(0., 1. - z * z));
    return vec3(r*cos(phi), r*sin(phi), z);
}

float calcAO(vec3 p, vec3 n) {
    const int N = 4;
    const float R = PARTICLE_RADIUS*2;
    const float eps = 0.01;
    const float falloff = 0.09;

    float occ = 0.0;

    vec3 p0 = p + n * eps;

    mat3 TBN = buildBasis(n);

    for (int j = 0; j < N; ++j) {
        vec3 seed = hash33((p + fract(time) + j)*47);
        vec3 dir = sampleHemisphereDir(seed.xy);
        dir = TBN * dir;

        float u = seed.z;
        float r = R * pow(u, 1.0 / 3.0); // uniform in hemisphere volume

        vec3 x = p0 + dir * r;
        float d = map(x).w;

        float blocked = 1.0 - smoothstep(0.0, falloff, d);
        occ += blocked;
    }

    float ao = 1.0 - occ / float(N);
    return clamp(ao, 0.0, 1.0);
}

const vec3 LIGHT_DIR = normalize(vec3(1,1,-1));
const vec3 SUN_COL = vec3(1);
const vec3 SKY_COL = vec3(0.4, 0.7, 1.0);
const float SUN_STRENGTH = 5;

vec4 render(vec3 ro, vec3 rd){
    float shad;

    // primary ray
    vec4 hit = sceneIntersect(ro, rd, shad);
    float tprim = hit.w;
    if (tprim < 0.) {
        return vec4(mix(SKY_COL, SUN_COL, 0.5*dot(rd, LIGHT_DIR) + 0.5), 0);
    }

    vec3 p = ro + rd * tprim;

    vec3 N = normalize(hit.xyz);
    vec3 V = -rd;
    vec3 L = LIGHT_DIR;
    vec3 H = normalize(V + L);
    vec3 eps = N*2*RM_EPS;

    vec3 q = p - barycenter.xyz;
    float g = smoothstep(0.7, 1.5, length(q));
    float a = 0.1*time;
    q.xz *= rot(a);
    q.zy *= rot(a);
    q *= 10.;
    float nn = noise(q);
    float f = step(0.5, nn);
    //float s = smoothstep(0.55,0.5,nn);

    vec3 albedo = mix(mix(vec3(1), vec3(1,0.5, 0.6), g), vec3(1.0,1.0,0.7), f);
    //float roughness = mix(mix(0.5, 0.2, f), 0.05, s*f);
    float roughness = mix(0.5, 0.2, f);

    vec3 F0 = mix(vec3(0.04), albedo, f);
    
    // shadows
    hit = sceneIntersect(p + eps, L, shad);
    vec3 Li = shad * SUN_STRENGTH * SUN_COL;
    
    // cook-torrance BRDF
    float ND = D_GGX(N, H, roughness);
    float G = G_Smith(N, V, L, roughness);
    vec3 F = F_Schlick(max(dot(H, V), 0.), F0);
    
    vec3 kS = F;
    vec3 kD = vec3(1) - kS;
    kD *= 1 - f;

    // add to outgoing radiance Lo
    float NdotL = max(dot(N, L), 0.);
    float NdotV = max(dot(N, V), 0.);
    vec3 diffuse = kD * albedo / PI;
    vec3 specular = ND * G * F / (4.*NdotV*NdotL + 0.0001);
    vec3 Lo = (diffuse + specular)*Li*NdotL + SKY_COL*albedo*calcAO(p, N);

    return vec4(Lo, tprim);
}

const float dur = 5.0;
const float off = 0.28;
float musicTime = 0;
float musicTimeLoop = 0;

vec4 FM(vec4 fc, vec4 fm, float iom) {
    return sin(TWOPI*fract(fc*musicTime) + iom*sin(TWOPI*fract(fm*musicTime)));
}

float chord(ivec4 ns) {
    vec4 f = 440. * pow(vec4(2.), vec4(ns - 69) / 12.);
    vec4 s = FM(f, f, 0.65) * 0.15
        + FM(2.0*f, f, 0.40) * 0.06
        + FM(f, 2.0*f, 0.45) * 0.025
        + FM(0.5*f, f, 0.25) * 0.015;
    return dot(s,vec4(1));
}

void fade(ivec4 c, float i, inout float s) {
    s = mix(s, chord(c), smoothstep((i-1)*dur + off, i*dur, musicTimeLoop));
}

void generateMusic(int id) {
    int numSamples = musicBuffer.length();
    int samplesPerInvoc = 1024;
    float maxAmplitude = 32767./16.; // must be less or equal than 32767

    int start = id * samplesPerInvoc;
    int end = min(start + samplesPerInvoc, numSamples);
    if (start >= numSamples) return;

    for(int i = start; i < end; i++) {
        musicTime = float(i)/float(sampleRate);
        musicTimeLoop = mod(musicTime, 10*dur);
        float s = chord(ivec4(55, 60, 62, 65));
        fade(ivec4(55, 60, 64, 67), 1.0 - off / dur, s);
        fade(ivec4(57, 60, 64, 71), 1, s);
        fade(ivec4(57, 60, 65, 67), 2, s);
        fade(ivec4(55, 60, 64, 67), 3, s);
        fade(ivec4(57, 60, 62, 65), 4, s);
        fade(ivec4(57, 60, 65, 69), 5, s);
        fade(ivec4(55, 60, 62, 67), 6, s);
        fade(ivec4(60, 64, 69, 72), 7, s);
        fade(ivec4(59, 62, 67, 71), 8, s);
        fade(ivec4(57, 60, 64, 69), 9, s);
        fade(ivec4(55, 60, 62, 65), 10, s);
        s *= smoothstep(0., 1., musicTime)*smoothstep(180., 175., musicTime);
        musicBuffer[i] = clamp(s, -1., 1.) * maxAmplitude;
    }
}

